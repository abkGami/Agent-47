# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Privy Authentication (https://privy.io)
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Solana RPC Configuration
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key
# Or use public RPC: https://api.devnet.solana.com

# Jupiter API Key (https://portal.jup.ag - Free tier available)
JUPITER_API_KEY=your_jupiter_api_key_here

# Optional: Birdeye API for price data
BIRDEYE_API_KEY=your_birdeye_key_here

# Network: devnet or mainnet
NETWORK=devnet
